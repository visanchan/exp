# Normalize line endings: LF in the repository, native in the working tree.
* text=auto

# Always LF, regardless of platform.
*.sh   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
