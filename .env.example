# ---------------------------------------------------------------------------
# .env.example — placeholder names only.
#
# Copy to .env and fill in real values locally. NEVER commit .env.
#   cp .env.example .env
#
# Rules:
#   - Leave every value blank in this file.
#   - Do not paste real keys, tokens, passwords, or URLs here.
#   - Add new variable NAMES here whenever an experiment needs one.
#   - Variables prefixed NEXT_PUBLIC_ / VITE_ / PUBLIC_ are exposed to the
#     browser. Never put a secret behind those prefixes.
# ---------------------------------------------------------------------------

# --- AI / model providers --------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_API_TOKEN=

# Text-model list price in USD per MILLION tokens, used only for cost
# reporting (exp-003 criterion C6). Optional: when unset, a run reports its
# token counts and marks the dollar figure unpriced rather than guessing.
OPENAI_TEXT_PRICE_INPUT=
OPENAI_TEXT_PRICE_OUTPUT=

# --- Local binaries --------------------------------------------------------
# Optional. Path to an existing ffmpeg.exe for exp-003's MP4 export. When
# unset, it is discovered on PATH or in the usual install locations.
FFMPEG_BINARY=

# --- Application -----------------------------------------------------------
APP_ENV=
PORT=
LOG_LEVEL=
NEXT_PUBLIC_APP_URL=

# --- Database / storage ----------------------------------------------------
DATABASE_URL=
REDIS_URL=

# --- Auth ------------------------------------------------------------------
AUTH_SECRET=
JWT_SECRET=

# --- Third-party services --------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
GITHUB_TOKEN=
